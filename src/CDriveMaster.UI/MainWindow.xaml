<Window x:Class="CDriveMaster.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:CDriveMaster.UI.ViewModels"
        xmlns:views="clr-namespace:CDriveMaster.UI.Views"
        Title="CDriveMaster"
        Height="860"
        Width="1440"
        MinHeight="760"
        MinWidth="1200"
        Background="#FFF4F7FB">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:SystemMaintenanceAnalysisViewModel}">
            <views:SystemMaintenanceAnalysisView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:GenericCleanupViewModel}">
            <views:GenericCleanupView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:BasicScanDashboardViewModel}">
            <views:LargeFileScannerView />
        </DataTemplate>

        <Style x:Key="SideNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="Foreground" Value="#FFE2E8F0" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14233A" />
                    <Setter Property="BorderBrush" Value="#334155" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="18"
                Background="#FF0F172A"
                BorderBrush="#1E293B"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="C 盘清理大师"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FFF8FAFC" />
                    <TextBlock Margin="0,6,0,0"
                               Text="统一的系统瘦身、应用清理和分析工作台。"
                               TextWrapping="Wrap"
                               Foreground="#FFCBD5E1" />
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,18,0,18"
                        Padding="14"
                        Background="#FF162033"
                        BorderBrush="#FF334155"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="产品工作台"
                                   FontSize="12"
                                   Foreground="#FF94A3B8" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="左侧用于切换模块和查看工具入口，右侧始终展示当前模块的完整工作区。"
                                   TextWrapping="Wrap"
                                   Foreground="#FFE2E8F0" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2">
                    <TextBlock Margin="0,0,0,10"
                               Text="核心功能"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#FF94A3B8" />

                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Content="系统瘦身"
                            Command="{Binding MapsToSystemMaintenanceCommand}" />

                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Content="应用清理"
                            Command="{Binding MapsToAppCleanupCommand}" />

                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Content="常规清理"
                            Command="{Binding MapsToLargeFileAnalysisCommand}" />

                    <TextBlock Margin="0,18,0,10"
                               Text="辅助工具"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#FF94A3B8" />

                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Content="规则配置"
                            Command="{Binding OpenRulesFolderCommand}" />

                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Content="审计日志"
                            Command="{Binding OpenLogsFolderCommand}" />

                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Content="帮助文档"
                            Command="{Binding OpenHelpDocsCommand}" />

                    <Button Style="{StaticResource SideNavButtonStyle}"
                            Content="导出诊断包"
                            Command="{Binding ExportDiagnosticsCommand}" />
                </StackPanel>

                <Border Grid.Row="3"
                        Padding="12"
                        Background="#FF162033"
                        BorderBrush="#FF334155"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="当前版本"
                                   FontSize="12"
                                   Foreground="#FF94A3B8" />
                        <TextBlock Margin="0,4,0,0"
                                   Text="{Binding AppVersion}"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF8FAFC" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Padding="0"
                Background="#00000000"
                CornerRadius="16">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</Window>
