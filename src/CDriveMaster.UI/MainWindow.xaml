<Window x:Class="CDriveMaster.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CDriveMaster.UI.Converters"
        Title="C盘管理大师 - M3 多路径聚合" Height="700" Width="1000">

    <Window.Resources>
        <conv:FileSizeConverter x:Key="FileSizeConv"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="C盘管理大师" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="核心用户目录空间分析" FontSize="16" Foreground="Gray"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="开始全面扫描" Command="{Binding ScanCommand}" Width="160" Height="36" Margin="0,0,10,0"/>
                <Button Content="取消扫描" Command="{Binding ScanCancelCommand}" Width="120" Height="36"/>
                <Button Content="清理 Temp 垃圾" Command="{Binding CleanTempCommand}" Width="130" Height="36" Margin="10,0,0,0"/>
            </StackPanel>

            <Border Grid.Column="2" Background="#FFF3F3F3" BorderBrush="#DDDDDD" BorderThickness="1" Padding="10" CornerRadius="4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="回收站占用: " VerticalAlignment="Center" Foreground="Gray"/>
                    <TextBlock Text="{Binding RecycleBinState.SizeBytes, Converter={StaticResource FileSizeConv}}"
                               FontWeight="Bold" Foreground="#D83B01" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding RecycleBinState.ItemCount, StringFormat=({0} 项)}"
                               Foreground="Gray" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Content="清空回收站" Command="{Binding EmptyRecycleBinCommand}"
                            Width="100" Height="28" Background="#D83B01" Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <ProgressBar Minimum="0" Maximum="100"
                         Value="{Binding ProgressValue}"
                         Height="15" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="14" Foreground="DarkBlue" TextWrapping="Wrap"/>
        </StackPanel>

        <ItemsControl Grid.Row="3" ItemsSource="{Binding LastSnapshot.CategoryStats}" Margin="0,0,0,15">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#DDDDDD" BorderThickness="1" Margin="0,0,10,0" Padding="15" Background="#F9F9F9">
                        <StackPanel>
                            <TextBlock Text="{Binding Category}" FontWeight="Bold" FontSize="16" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalBytes, Converter={StaticResource FileSizeConv}}" FontSize="20" Foreground="#005A9E"/>
                            <TextBlock Text="{Binding TotalFiles, StringFormat=文件数: {0}}" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TabControl Grid.Row="4" BorderBrush="#DDDDDD" BorderThickness="1">
            <TabItem Header="Top 20 大文件">
                <DataGrid ItemsSource="{Binding LastSnapshot.LargestFiles}"
                          SelectedItem="{Binding SelectedFile}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          GridLinesVisibility="Horizontal" BorderThickness="0">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="移至回收站 (安全删除)"
                                      Command="{Binding PlacementTarget.DataContext.DeleteToRecycleBinCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      Foreground="#D83B01" FontWeight="Bold"/>
                            <Separator/>
                            <MenuItem Header="打开所在文件夹"
                                      Command="{Binding PlacementTarget.DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="复制完整路径"
                                      Command="{Binding PlacementTarget.DataContext.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="文件名" Binding="{Binding Name}" Width="250"/>
                        <DataGridTextColumn Header="大小" Binding="{Binding Size, Converter={StaticResource FileSizeConv}}" Width="120"/>
                        <DataGridTextColumn Header="修改时间" Binding="{Binding LastWriteTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="150"/>
                        <DataGridTextColumn Header="路径" Binding="{Binding Path}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Top 20 大目录">
                <DataGrid ItemsSource="{Binding LastSnapshot.LargestDirectories}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          GridLinesVisibility="Horizontal" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="目录路径" Binding="{Binding Path}" Width="350"/>
                        <DataGridTextColumn Header="总大小" Binding="{Binding TotalBytes, Converter={StaticResource FileSizeConv}}" Width="120"/>
                        <DataGridTextColumn Header="包含文件数" Binding="{Binding FileCount}" Width="100"/>
                        <DataGridTextColumn Header="子目录数" Binding="{Binding SubdirectoryCount}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="跳过路径 (拦截记录)">
                <DataGrid ItemsSource="{Binding LastSnapshot.Issues}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          GridLinesVisibility="Horizontal" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="拦截原因" Binding="{Binding Reason}" Width="200"/>
                        <DataGridTextColumn Header="具体路径" Binding="{Binding Path}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Temp 清理报告">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Rows="2" Columns="4" Margin="0,0,0,15">
                        <StackPanel Margin="5">
                            <TextBlock Text="释放空间" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.ReleasedBytes, Converter={StaticResource FileSizeConv}}" FontSize="18" FontWeight="Bold" Foreground="#005A9E"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="成功删除文件" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.DeletedFileCount}" FontSize="18" FontWeight="Bold" Foreground="DarkGreen"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="成功删除目录" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.DeletedDirectoryCount}" FontSize="18" FontWeight="Bold" Foreground="DarkGreen"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="因占用跳过 (锁定)" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.SkippedLockedFileCount}" FontSize="18" FontWeight="Bold" Foreground="#D83B01"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="1小时保护期内跳过" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.SkippedTooNewCount}" FontSize="18" FontWeight="Bold" Foreground="Orange"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="无权限跳过" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.SkippedAccessDeniedCount}" FontSize="18" FontWeight="Bold" Foreground="#D83B01"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="重解析点/离线跳过" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.SkippedReparsePointCount}" FontSize="18" FontWeight="Bold" Foreground="Purple"/>
                        </StackPanel>
                        <StackPanel Margin="5">
                            <TextBlock Text="目录清理失败" Foreground="Gray"/>
                            <TextBlock Text="{Binding LastTempCleanupResult.FailedDirectoryDeleteCount}" FontSize="18" FontWeight="Bold" Foreground="#D83B01"/>
                        </StackPanel>
                    </UniformGrid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding LastTempCleanupResult.SampleIssues}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              GridLinesVisibility="Horizontal" BorderBrush="#DDDDDD" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="动作拦截原因" Binding="{Binding Reason}" Width="250"/>
                            <DataGridTextColumn Header="受保护路径 (最多显示 50 条样本)" Binding="{Binding Path}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
