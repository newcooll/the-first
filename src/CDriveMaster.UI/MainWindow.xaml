<Window x:Class="CDriveMaster.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:CDriveMaster.UI.ViewModels"
        xmlns:views="clr-namespace:CDriveMaster.UI.Views"
        Title="CDriveMaster.UI" Height="500" Width="760">

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:SystemMaintenanceViewModel}">
            <views:SystemMaintenanceView />
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <ContentControl Content="{Binding CurrentViewModel}" />
    </Grid>
</Window>
