<UserControl x:Class="CDriveMaster.UI.Views.LargeFileScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:CDriveMaster.UI.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
    </UserControl.Resources>

    <Grid Background="#FFF7FAFC">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="16"
                CornerRadius="10"
                Background="#FFFAFCFF"
                BorderBrush="#FFD9E4EE"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.18" Color="#FF9AA7B8" />
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="14" Foreground="#FF4B5565" Text="已发现可释放空间" />
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF0F3E66"
                               Text="{Binding TotalFoundBytes, Converter={StaticResource FileSizeConverter}}" />
                </StackPanel>

                <StackPanel Margin="30,0,0,0" DockPanel.Dock="Left">
                    <TextBlock FontSize="14" Foreground="#FF4B5565" Text="已勾选可清理" />
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#FF1D6B3C"
                               Text="{Binding TotalSelectedBytes, Converter={StaticResource FileSizeConverter}}" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="#FF667085"
                               Text="{Binding SelectedCount, StringFormat={}({0} 项)}" />
                </StackPanel>

                <StackPanel Margin="30,0,0,0" VerticalAlignment="Center" DockPanel.Dock="Right">
                    <TextBlock Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis"
                               Foreground="#FF1D4D7A" />
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding StatsText}"
                               Foreground="#FF667085" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Padding="12"
                Background="#FFFFFBF3"
                BorderBrush="#FFF6E4B8"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <TextBlock Text="🔥 热门应用缓存热点"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#FF7A3E00"
                           Margin="0,0,0,10" />

                <ItemsControl ItemsSource="{Binding AppHotspots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="250"
                                    Margin="0,0,10,10"
                                    Padding="12"
                                    Background="#FFFFFFFF"
                                    BorderBrush="#FFE5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#FFE5E7EB" />
                                        <Setter Property="Opacity" Value="0.6" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHotspot}" Value="True">
                                                <Setter Property="BorderBrush" Value="#FFE53935" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🧩"
                                                   FontSize="14"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding AppName}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF1F2937" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHotspot}" Value="True">
                                                            <Setter Property="Foreground" Value="#FFE53935" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Margin="8,0,0,0"
                                                   Text="[实验性支持] 检测到可疑路径，未达热点阈值"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF667085"
                                                   Visibility="Collapsed">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHotspot}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border Margin="8,0,0,0"
                                                Padding="6,2"
                                                Background="#FFFFF3E0"
                                                BorderBrush="#FFFFB74D"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                ToolTip="该应用的缓存路径基于社区经验，正在持续验证中"
                                                Visibility="Collapsed">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsExperimental}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="[实验性支持]"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFE65100" />
                                        </Border>
                                        <Border Margin="8,0,0,0"
                                                Padding="6,2"
                                                Background="#FFFFEBEE"
                                                BorderBrush="#FFF8BBD0"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Visibility="Collapsed">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHotspot}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="⚠️ 发现大量缓存"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFE53935" />
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding DisplaySize}"
                                               FontSize="30"
                                               Margin="0,6,0,2">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#FF0F3E66" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHotspot}" Value="True">
                                                        <Setter Property="Foreground" Value="#FFE53935" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="📂 目标位置: "
                                                   Foreground="#FF667085"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PrimaryPath, TargetNullValue=未确认 (未找到稳定根路径), FallbackValue=未确认 (未找到稳定根路径)}"
                                                   Foreground="#FF667085"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding PrimaryPath}"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="ToolTip" Value="{Binding PrimaryPath}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding PrimaryPath}" Value="{x:Null}">
                                                            <Setter Property="ToolTip" Value="当前规则命中热点，但未找到稳定根路径" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="查看详情"
                                                Padding="10,4"
                                                Margin="0,0,8,0"
                                                HorizontalAlignment="Left"
                                                Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding .}"
                                                ToolTip="查看探测链路详情" />

                                        <Button Content="🗑️ 清理此项"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                Command="{Binding DataContext.CleanHotspotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding .}"
                                                IsEnabled="{Binding IsHotspot}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="ToolTip" Value="常规缓存，安全可清理" />
                                                    <Setter Property="BorderBrush" Value="#FFDC2626" />
                                                    <Setter Property="Foreground" Value="#FFB91C1C" />
                                                    <Setter Property="Background" Value="#FFFEE2E2" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHeuristicMatch}" Value="True">
                                                            <Setter Property="ToolTip" Value="启发式深层缓存，清理需谨慎" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="1" Margin="0,8,0,10" Background="#FFE5E7EB" />

                <TextBlock Text="🧹 卸载残留 / 深层缓存热点"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#FF4B5565"
                           Margin="0,0,0,10" />

                <ItemsControl ItemsSource="{Binding ResidualHotspots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="270"
                                    Margin="0,0,10,10"
                                    Padding="12"
                                    Background="#FFFCFCFD"
                                    BorderBrush="#FFD0D5DD"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding AppName, StringFormat={}{0} - 深层残留}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#FF344054" />

                                    <TextBlock Text="{Binding DisplaySize}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#FF101828"
                                               Margin="0,6,0,4" />

                                    <TextBlock Text="{Binding PrimaryPath}"
                                               FontSize="12"
                                               Foreground="#FF667085"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding PrimaryPath}" />

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="查看详情"
                                                Margin="0,0,8,0"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding .}" />

                                        <Button Content="🗑️ 清理此项"
                                                Padding="10,4"
                                                HorizontalAlignment="Left"
                                                Command="{Binding DataContext.CleanHotspotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding .}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="ToolTip" Value="常规缓存，安全可清理" />
                                                    <Setter Property="BorderBrush" Value="#FFDC2626" />
                                                    <Setter Property="Foreground" Value="#FFB91C1C" />
                                                    <Setter Property="Background" Value="#FFFEE2E2" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHeuristicMatch}" Value="True">
                                                            <Setter Property="ToolTip" Value="启发式深层缓存，清理需谨慎" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,10"
                Padding="12"
                Background="#FFFFFFFF"
                BorderBrush="#FFD8E1EA"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Command="{Binding ScanFastCommand}"
                            Width="170"
                            Height="32"
                            Margin="0,0,10,0"
                            Background="#FFE8F6EC"
                            Foreground="#FF1D6B3C"
                            Content="快速扫描 (推荐)" />

                    <Button Command="{Binding ScanFullCommand}"
                            Width="150"
                            Height="32"
                            Margin="0,0,10,0"
                            Content="全盘深度扫描" />

                    <Button Command="{Binding CancelScanCommand}"
                            Width="120"
                            Height="32"
                            Background="#FFFDEBEC"
                            Foreground="#FFB42318"
                            BorderBrush="#FFFECACA"
                            Content="停止扫描" />
                </StackPanel>

                <ProgressBar Height="8"
                             Margin="0,0,0,6"
                             Value="{Binding ProgressValue}"
                             IsIndeterminate="{Binding IsIndeterminate}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ScanGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12"
                                Padding="14"
                                CornerRadius="8"
                                Background="#FFFFFFFF"
                                BorderBrush="#FFE0E7EF"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#FF102A43" />
                                <TextBlock Margin="0,4,0,10"
                                           Text="{Binding Description}"
                                           Foreground="#FF667085" />

                                <DataGrid ItemsSource="{Binding Items}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          SelectionMode="Single"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="选择" Width="70">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEnabled="{Binding IsSelectable}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="分类" Width="180">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" ToolTip="{Binding Recommendation.Reason}">
                                                        <TextBlock Text="{Binding Recommendation.Title}"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FF102A43" />
                                                        <TextBlock Margin="6,0,0,0"
                                                                   Text="[?]"
                                                                   Foreground="#FF2563EB"
                                                                   FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="文件路径/名称" Binding="{Binding FullPath}" Width="*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="大小" Binding="{Binding DisplaySize}" Width="120" IsReadOnly="True" />

                                        <DataGridTemplateColumn Header="建议动作" Width="220">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Recommendation.ActionText}"
                                                               Foreground="#FF0B6A99"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               ToolTip="{Binding Recommendation.Reason}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="操作" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="打开目录"
                                                            Padding="8,2"
                                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="4"
                Margin="0,10,0,0"
                Padding="12"
                Background="#FFFFFFFF"
                BorderBrush="#FFD8E1EA"
                BorderThickness="1"
                CornerRadius="8">
            <DockPanel>
                <TextBlock VerticalAlignment="Center"
                           Foreground="#FF667085"
                           Text="仅允许执行 ActionType=CleanSelected 且 RiskLevel=SafeAuto 的勾选项" />

                <Button DockPanel.Dock="Right"
                        Width="200"
                        Height="36"
                        Margin="12,0,0,0"
                        Content="一键清理已勾选安全项"
                        Command="{Binding ExecuteCleanSelectedCommand}"
                        Background="#FFE9F6EC"
                        Foreground="#FF1F7A40"
                        BorderBrush="#FFBDE3C8" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
