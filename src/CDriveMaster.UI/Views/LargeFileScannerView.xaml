<UserControl x:Class="CDriveMaster.UI.Views.LargeFileScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:CDriveMaster.UI.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:FileSizeConverter x:Key="FileSizeConverter" />
    </UserControl.Resources>

    <Grid Background="#FFF4F7FB">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="18" Background="#FF0F172A" CornerRadius="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="C 盘常规清理" FontSize="22" FontWeight="Bold" Foreground="#FFF8FAFC" />
                    <TextBlock Margin="0,6,0,0"
                               Text="左侧集中放扫描入口、C 盘空间和主操作，右侧专注结果与详情。"
                               TextWrapping="Wrap"
                               Foreground="#FFCBD5E1" />

                    <Border Margin="0,18,0,0" Padding="16" Background="#FF162033" BorderBrush="#FF334155" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="发现空间" FontSize="12" Foreground="#FF94A3B8" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding TotalFoundBytes, Converter={StaticResource FileSizeConverter}}" FontSize="30" FontWeight="Bold" Foreground="#FFF8FAFC" />
                            <Border Margin="0,12,0,10" Height="1" Background="#FF334155" />
                            <TextBlock Text="C 盘可用空间" FontSize="12" Foreground="#FF94A3B8" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding CDriveFreeBytes, Converter={StaticResource FileSizeConverter}}" FontSize="24" FontWeight="SemiBold" Foreground="#FF93C5FD" />
                            <TextBlock Margin="0,2,0,0" Text="{Binding CDriveUsageText}" TextWrapping="Wrap" Foreground="#FFCBD5E1" />
                            <Border Margin="0,12,0,10" Height="1" Background="#FF334155" />
                            <TextBlock Text="已勾选清理" FontSize="12" Foreground="#FF94A3B8" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding TotalSelectedBytes, Converter={StaticResource FileSizeConverter}}" FontSize="24" FontWeight="SemiBold" Foreground="#FF86EFAC" />
                            <TextBlock Margin="0,2,0,0" Text="{Binding SelectedCount, StringFormat={}已选择 {0} 项}" Foreground="#FFCBD5E1" />
                        </StackPanel>
                    </Border>

                    <Button Height="56"
                            Margin="0,18,0,0"
                            Command="{Binding ExecuteCleanSelectedCommand}"
                            Background="#FF22C55E"
                            BorderBrush="#FF86EFAC"
                            Foreground="#FF052E16"
                            FontSize="16"
                            FontWeight="Bold"
                            Content="立即清理已勾选安全项" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding TotalSelectedBytes, Converter={StaticResource FileSizeConverter}, StringFormat={}本次将处理已勾选空间：{0}}"
                               TextWrapping="Wrap"
                               Foreground="#BBF7D0" />

                    <TextBlock Margin="0,22,0,8" Text="扫描模式" FontSize="13" FontWeight="SemiBold" Foreground="#FFE2E8F0" />
                    <Button Height="40" Margin="0,0,0,10" Command="{Binding ScanFastCommand}" Background="#FFE8F6EC" BorderBrush="#FFD1FADF" Foreground="#FF166534" Content="快速扫描（推荐）" />
                    <Button Height="40" Margin="0,0,0,10" Command="{Binding ScanAppDeepCommand}" Background="#FFF5F3FF" BorderBrush="#FFE9D5FF" Foreground="#FF6D28D9" Content="应用深度扫描" />
                    <Button Height="40" Margin="0,0,0,10" Command="{Binding ScanFullCommand}" Background="#FFF8FAFC" BorderBrush="#FFCBD5E1" Foreground="#FF0F172A" Content="全盘深度扫描" />
                    <Button Height="40" Margin="0,0,0,18" Command="{Binding CancelScanCommand}" Background="#FFFDEBEC" BorderBrush="#FFFECACA" Foreground="#FFB42318" Content="停止扫描" />

                    <Border Padding="14" Background="#FF162033" BorderBrush="#FF334155" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="扫描状态" FontSize="12" Foreground="#FF94A3B8" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="#FFF8FAFC" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding StatsText}" TextWrapping="Wrap" Foreground="#FFCBD5E1" />
                            <ProgressBar Height="8" Margin="0,12,0,0" Value="{Binding ProgressValue}" IsIndeterminate="{Binding IsIndeterminate}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="18" Background="#FFFAFCFF" BorderBrush="#FFD9E4EE" BorderThickness="1" CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="扫描结果工作区" FontSize="24" FontWeight="Bold" Foreground="#FF102A43" />
                        <TextBlock Margin="0,6,0,0" Text="右侧集中展示热点、模糊归因残留、大文件雷达和清理明细。" TextWrapping="Wrap" Foreground="#FF667085" />
                    </StackPanel>
                    <Border Grid.Column="1" Padding="12" Background="#FFF0FDF9" BorderBrush="#FF99F6E4" BorderThickness="1" CornerRadius="10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCleanupVisualVisible}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding CleanupStageText, StringFormat={}清理阶段: {0}}" Foreground="#FF115E59" FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding CleanupSummaryText}" TextWrapping="Wrap" Foreground="#FF0F766E" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding CleanupBatchText}" TextWrapping="Wrap" Foreground="#FF0F766E" />
                            <ProgressBar Height="6" Margin="0,8,0,0" Value="{Binding ProgressValue}" IsIndeterminate="{Binding IsIndeterminate}" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding CleanupProgressText}" TextWrapping="Wrap" Foreground="#FF134E4A" FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding CleanupStorageImpactText}" TextWrapping="Wrap" Foreground="#FF0F766E" />
                            <TextBlock Margin="0,4,0,0" Text="{Binding CleanupCurrentPathText}" TextTrimming="CharacterEllipsis" Foreground="#FF667085" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,14,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Padding="14" Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="已确认应用热点" Foreground="#FFB42318" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding AppHotspots.Count, StringFormat={}共 {0} 项}" FontSize="24" FontWeight="Bold" Foreground="#FF101828" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="14" Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="常见应用深层残留" Foreground="#FF475467" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding CommonAppCaches.Count, StringFormat={}共 {0} 项}" FontSize="24" FontWeight="Bold" Foreground="#FF101828" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Padding="14" Background="#FFFFFFFF" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="深层残留 / 清理项" Foreground="#FF0F3E66" FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ResidualHotspots.Count, StringFormat={}共 {0} 项}" FontSize="24" FontWeight="Bold" Foreground="#FF101828" />
                    </StackPanel>
                </Border>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Padding="16" Background="#FFFFFBF3" BorderBrush="#FFF6E4B8" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="🔥 已确认应用热点" FontSize="16" FontWeight="SemiBold" Foreground="#FF7A3E00" Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding AppHotspots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="280" Margin="0,0,12,12" Padding="14" Background="#FFFFFFFF" BorderBrush="#FFE5E7EB" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding AppName}" FontSize="14" FontWeight="SemiBold" Foreground="#FF1F2937" />
                                                <TextBlock Text="{Binding DisplaySize}" FontSize="30" Margin="0,8,0,4" FontWeight="Bold" Foreground="#FF0F3E66" />
                                                <TextBlock Text="{Binding PrimaryPath}" FontSize="12" Foreground="#FF667085" TextTrimming="CharacterEllipsis" ToolTip="{Binding PrimaryPath}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <Button Content="查看详情" Padding="10,4" Margin="0,0,8,0" Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding .}" />
                                                    <Button Content="🗑️ 清理此项" Padding="10,4" Command="{Binding DataContext.CleanHotspotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding .}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Height="1" Margin="0,8,0,12" Background="#FFE5E7EB" />
                            <TextBlock Text="🧩 常见应用深层残留" FontSize="16" FontWeight="SemiBold" Foreground="#FF4B5565" Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding CommonAppCaches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14" Background="#FFFFFFFF" BorderBrush="#FFD0D5DD" BorderThickness="1" CornerRadius="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="常见应用深层残留" FontSize="15" FontWeight="SemiBold" Foreground="#FF344054" />
                                                    <TextBlock Margin="0,8,0,0" Text="{Binding Category}" Foreground="#FF667085" FontSize="12" TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,8,0,0" Text="{Binding PrimaryPath}" Foreground="#FF667085" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding PrimaryPath}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="18,0,0,0" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding DisplaySize}" FontSize="30" FontWeight="Bold" Foreground="#FF0F3E66" HorizontalAlignment="Right" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Right">
                                                        <Button Content="查看详情" Padding="10,4" Margin="0,0,8,0" Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding .}" />
                                                        <Button Content="🗑️ 清理此项" Padding="10,4" Command="{Binding DataContext.CleanHotspotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding .}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Height="1" Margin="0,12,0,12" Background="#FFE5E7EB" />
                            <TextBlock Text="🧹 卸载残留 / 深层缓存热点" FontSize="16" FontWeight="SemiBold" Foreground="#FF4B5565" Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding ResidualHotspots}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="300" Margin="0,0,12,12" Padding="14" Background="#FFFCFCFD" BorderBrush="#FFD0D5DD" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding AppName}" FontSize="14" FontWeight="SemiBold" Foreground="#FF344054" />
                                                <TextBlock Text="{Binding Category}" Margin="0,4,0,0" FontSize="12" Foreground="#FF667085" />
                                                <TextBlock Text="{Binding DisplaySize}" FontSize="28" FontWeight="Bold" Foreground="#FF101828" Margin="0,8,0,4" />
                                                <TextBlock Text="{Binding PrimaryPath}" FontSize="12" Foreground="#FF667085" TextTrimming="CharacterEllipsis" ToolTip="{Binding PrimaryPath}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <Button Content="查看详情" Margin="0,0,8,0" Padding="10,4" Command="{Binding DataContext.ViewDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding .}" />
                                                    <Button Content="🗑️ 清理此项" Padding="10,4" Command="{Binding DataContext.CleanHotspotCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding .}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,14,0,0" Padding="16" Background="#FFFFFFFF" BorderBrush="#FFD8E1EA" BorderThickness="1" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="扫描明细与大文件雷达" FontSize="16" FontWeight="SemiBold" Foreground="#FF102A43" />
                            <TextBlock Margin="0,4,0,10" Text="这里保留扫描分组、Top 20 大文件和可安全清理明细。" Foreground="#FF667085" />
                            <ItemsControl ItemsSource="{Binding ScanGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="14" CornerRadius="8" Background="#FFF8FAFC" BorderBrush="#FFE0E7EF" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#FF102A43" />
                                                <TextBlock Margin="0,4,0,10" Text="{Binding Description}" Foreground="#FF667085" />
                                                <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" IsReadOnly="False" HeadersVisibility="Column">
                                                    <DataGrid.Columns>
                                                        <DataGridTemplateColumn Header="选择" Width="70">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsSelectable}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Header="分类" Width="180">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" ToolTip="{Binding Recommendation.Reason}">
                                                                        <TextBlock Text="{Binding Recommendation.Title}" FontWeight="Bold" Foreground="#FF102A43" />
                                                                        <TextBlock Margin="6,0,0,0" Text="[?]" Foreground="#FF2563EB" FontWeight="SemiBold" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTextColumn Header="文件路径/名称" Binding="{Binding FullPath}" Width="*" IsReadOnly="True" />
                                                        <DataGridTextColumn Header="大小" Binding="{Binding DisplaySize}" Width="120" IsReadOnly="True" />
                                                        <DataGridTemplateColumn Header="建议动作" Width="220">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Recommendation.ActionText}" Foreground="#FF0B6A99" FontWeight="SemiBold" TextWrapping="Wrap" ToolTip="{Binding Recommendation.Reason}" />
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                        <DataGridTemplateColumn Header="操作" Width="110">
                                                            <DataGridTemplateColumn.CellTemplate>
                                                                <DataTemplate>
                                                                    <Button Content="打开目录" Padding="8,2" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
                                                                </DataTemplate>
                                                            </DataGridTemplateColumn.CellTemplate>
                                                        </DataGridTemplateColumn>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
