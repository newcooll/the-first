<UserControl x:Class="CDriveMaster.UI.Views.GenericCleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:CDriveMaster.UI.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <converters:TakeItemConverter x:Key="TakeItemConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="选择应用:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Width="180"
                      ItemsSource="{Binding AvailableApps}"
                      SelectedItem="{Binding SelectedApp}"
                      DisplayMemberPath="AppName"
                      Margin="0,0,10,0" />

            <Button Command="{Binding ScanCommand}"
                    Width="130"
                    Height="32"
                    Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="扫描选中应用" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Content" Value="正在扫描..." />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Command="{Binding ApplySafeAutoCommand}"
                    Width="170"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="#FFFBE9E7"
                    Foreground="DarkRed">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="一键清理 (仅安全项)" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Content" Value="正在清理..." />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Content="预览后清理 (需确认项)"
                    Command="{Binding ReviewAndApplyCommand}"
                    Width="180"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="#FFEAF4FF"
                    Foreground="#FF1E4E79" />

            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding BucketItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="清理项" Binding="{Binding CategoryDescription}" Width="*" />
                <DataGridTextColumn Header="风险等级" Binding="{Binding RiskLevelText}" Width="140" />
                <DataGridTextColumn Header="预估大小" Binding="{Binding FormattedEstimatedSize}" Width="140" />
                <DataGridTextColumn Header="分析状态" Binding="{Binding StatusText}" Width="120" />
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Margin="8,4,8,8"
                            Padding="10"
                            BorderBrush="#FFD5DEE8"
                            BorderThickness="1"
                            Background="#FFF8FBFF"
                            CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="⚠️ 抽样检查 (仅显示前 5 个即将被处理的文件路径)："
                                       FontSize="12"
                                       Foreground="#FF667085"
                                       Margin="0,0,0,6" />

                            <ItemsControl ItemsSource="{Binding OriginalResult.Bucket.Entries, Converter={StaticResource TakeItemConverter}, ConverterParameter=5}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled"
                                                      CanContentScroll="False">
                                            <TextBlock Text="{Binding Path}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas"
                                                       FontSize="12"
                                                       Foreground="#FF344054" />
                                        </ScrollViewer>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>

        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Padding="10"
                BorderBrush="#FFCCD7E1"
                BorderThickness="1"
                Background="#FFF7FAFC">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ExecutionSummary}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ExecutionSummary.SummaryMessage}" FontWeight="SemiBold" Margin="0,0,16,0" />
                <TextBlock Text="成功:" Margin="0,0,4,0" />
                <TextBlock Text="{Binding ExecutionSummary.SuccessCount}" Margin="0,0,12,0" />
                <TextBlock Text="失败:" Margin="0,0,4,0" />
                <TextBlock Text="{Binding ExecutionSummary.FailedCount}" Margin="0,0,12,0" />
                <TextBlock Text="释放:" Margin="0,0,4,0" />
                <TextBlock Text="{Binding ExecutionSummary.ReclaimedSizeText}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>