<UserControl x:Class="CDriveMaster.UI.Views.SystemMaintenanceAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Command="{Binding AnalyzeCommand}" Width="140" Height="32" Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="分析系统组件" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Content" Value="正在分析..." />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Command="{Binding OpenLogsFolderCommand}" Width="120" Height="32" Margin="0,0,10,0" Content="审计日志" />

            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="#FF245A94" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14"
                    BorderBrush="#FFD9DEE5"
                    BorderThickness="1"
                    Background="#FFF9FBFD"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="组件存储实际大小:" Margin="0,0,0,10" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ActualSizeText}" Margin="0,0,0,10" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="预计可回收空间:" Margin="0,0,0,10" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EstimatedReclaimableText}" Margin="0,0,0,10" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="系统是否建议清理:" Margin="0,0,0,10" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CleanupRecommended}" Margin="0,0,0,10" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="上次分析时间:" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastAnalysisTime}" FontWeight="SemiBold" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="0,10,0,0"
                       Text="{Binding RiskDescription}"
                       Foreground="DarkOrange"
                       TextWrapping="Wrap" />
        </Grid>

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Padding="12"
                BorderBrush="#FFCC4B37"
                BorderThickness="1"
                Background="#FFFFF1F0"
                Visibility="{Binding HasAnalysisResult, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="⚠️ 警告：即将调用 Windows 原生 DISM 组件清理。本操作不使用 /ResetBase，不会影响系统更新的卸载能力，但耗时较长。"
                           Foreground="#FFB00020"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />

                <CheckBox Content="我理解风险，同意执行系统组件清理"
                          IsChecked="{Binding IsConfirmed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Margin="0,0,0,8" />

                <Button Command="{Binding CleanupCommand}" Width="140" Height="32" HorizontalAlignment="Left">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Content" Value="执行真实清理" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Content" Value="正在清理中..." />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Padding="10"
                BorderBrush="#FFD9DEE5"
                BorderThickness="1"
                Background="#FFF9FBFD">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CleanupResult}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="清理状态:" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding CleanupResult.Status}" Margin="0,0,12,0" FontWeight="SemiBold" />
                    <TextBlock Text="耗时:" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding CleanupResult.Duration}" Margin="0,0,12,0" FontWeight="SemiBold" />
                    <TextBlock Text="退出码:" Margin="0,0,4,0" />
                    <TextBlock Text="{Binding CleanupResult.ExitCode}" FontWeight="SemiBold" />
                </StackPanel>

                <Button Command="{Binding ReAnalyzeCommand}"
                        Width="140"
                        Height="30"
                        HorizontalAlignment="Left"
                        Content="重新分析系统组件" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
