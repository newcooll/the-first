{
  "AppName": "Edge",
  "AppMatchKeywords": [
    "Edge",
    "Microsoft Edge"
  ],
  "Description": "Microsoft Edge 浏览器缓存清理规则（仅安全缓存目录）",
  "DefaultAction": "DeleteToRecycleBin",
  "FastScan": {
    "HotPaths": [
      "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data\\Default\\Cache",
      "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data\\Default\\Code Cache"
    ],
    "MaxDepth": 2,
    "MinSizeThreshold": 104857600,
    "Category": "BrowserCache",
    "IsExperimental": false
  },
  "Targets": [
    {
      "BaseFolder": "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data\\Default\\Cache",
      "Kind": "BrowserCache",
      "RiskLevel": "SafeAuto"
    },
    {
      "BaseFolder": "%LOCALAPPDATA%\\Microsoft\\Edge\\User Data\\Default\\Code Cache",
      "Kind": "BrowserCache",
      "RiskLevel": "SafeAuto"
    }
  ]
}
