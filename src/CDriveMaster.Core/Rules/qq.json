{
  "AppName": "QQ",
  "AppMatchKeywords": [
    "QQ",
    "Tencent QQ"
  ],
  "Description": "QQ 缓存与冗余文件清理",
  "DefaultAction": "DeleteToRecycleBin",
  "FastScan": {
    "HotPaths": [
      "%USERPROFILE%\\Documents\\Tencent Files"
    ],
    "MaxDepth": 2,
    "MinSizeThreshold": 52428800,
    "Category": "AppCache",
    "IsExperimental": false
  },
  "Targets": [
    {
      "BaseFolder": "*/Image",
      "Kind": "Image",
      "RiskLevel": "SafeWithPreview"
    },
    {
      "BaseFolder": "*/Video",
      "Kind": "Video",
      "RiskLevel": "SafeWithPreview"
    },
    {
      "BaseFolder": "*/PTT",
      "Kind": "Audio",
      "RiskLevel": "SafeWithPreview"
    },
    {
      "BaseFolder": "*/FileRecv",
      "Kind": "Download",
      "RiskLevel": "Blocked"
    }
  ]
}