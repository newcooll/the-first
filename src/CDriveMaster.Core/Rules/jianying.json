        "FileMarkersAny": ["draft", "cache", "temp", "preview"],
        "MaxDepth": 2,
        "MinCandidateBytes": 20971520
      },
      {
        "Parent": "%APPDATA%",
        "DirectoryKeywords": ["Jianying", "CapCut"],
        "ChildMarkersAny": ["User Data", "Cache"],
        "MaxDepth": 2,
        "MinCandidateBytes": 20971520
      }
    ],
    "MaxDepth": 2,
    "MinSizeThreshold": 20971520,
    "Category": "MediaCache",
    "IsExperimental": true
  },
  "Targets": [
    {
      "BaseFolder": "%LOCALAPPDATA%\\JianyingPro\\User Data\\Cache",
      "Kind": "MediaCache",
      "RiskLevel": "SafeWithPreview"
