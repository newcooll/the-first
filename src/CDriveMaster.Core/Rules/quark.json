{
  "AppName": "Quark",
  "AppMatchKeywords": [
    "夸克",
    "Quark",
    "QuarkCloud"
  ],
  "Description": "夸克缓存实验性清理规则",
  "DefaultAction": "DeleteToRecycleBin",
  "ResidualFingerprints": [
    {
      "Parent": "%APPDATA%",
      "PathKeywords": ["quark-cloud-drive", "pdf-cache", "pdf-viewer"],
      "MaxDepth": 4
    }
  ],
  "FastScan": {
    "HotPaths": [
      "%LOCALAPPDATA%\\Quark",
      "%PROGRAMDATA%\\Quark\\videoCache"
    ],
    "SearchHints": [
      {
        "Parent": "%LOCALAPPDATA%",
        "DirectoryKeywords": ["Quark", "QuarkCloud"],
        "ChildMarkersAny": ["Cache", "db", "Download", "videoCache", "Logs"],
        "FileMarkersAny": ["quark", "quark-cloud", "cache", "db"],
        "MaxDepth": 3,
        "MinCandidateBytes": 20971520
      },
      {
        "Parent": "%PROGRAMDATA%",
        "DirectoryKeywords": ["Quark"],
        "ChildMarkersAny": ["videoCache", "Cache"],
        "FileMarkersAny": ["quark"],
        "MaxDepth": 2,
        "MinCandidateBytes": 20971520
      }
    ],
    "MaxDepth": 2,
    "MinSizeThreshold": 20971520,
    "Category": "BrowserCache",
    "IsExperimental": true
  },
  "Targets": [
    {
      "BaseFolder": "%LOCALAPPDATA%\\Quark",
      "Kind": "BrowserCache",
      "RiskLevel": "SafeWithPreview"
    },
    {
      "BaseFolder": "%PROGRAMDATA%\\Quark\\videoCache",
      "Kind": "VideoCache",
      "RiskLevel": "SafeWithPreview"
    }
  ]
}
